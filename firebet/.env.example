# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/firebet
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication
JWT_SECRET=firebet-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# External APIs
RAPIDAPI_KEY=your_rapidapi_key_here
SPORTS_DATA_API_KEY=your_sports_data_api_key_here

# Fire API Integration
FIRE_API_BASE_URL=https://web-production-81c6a.up.railway.app
FIRE_API_KEY=your_fire_api_key_here

# Real-time Features
SOCKET_PORT=3001

# Logging
LOG_LEVEL=info
LOG_FILE=logs/firebet.log

# Sports API Configuration
BASKETBALL_API_BASE=https://api-basketball.p.rapidapi.com
SOCCER_API_BASE=https://api-football-v1.p.rapidapi.com
BASEBALL_API_BASE=https://api-baseball.p.rapidapi.com

# Cache Configuration
CACHE_TTL_GAMES=300
CACHE_TTL_ODDS=30
CACHE_TTL_PREDICTIONS=1800

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Firebase Configuration (if using)
FIREBASE_PROJECT_ID=firebet-e3db
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
